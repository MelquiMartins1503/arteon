# Database
DATABASE_URL="postgresql://user:password@localhost:5432/arteon?schema=public"
# DIRECT_URL is used for migrations/direct connection if using a transaction pooler like Supabase/Neon
# DIRECT_URL="postgresql://user:password@localhost:5432/arteon?schema=public"

# Auth
JWT_SECRET="super-secret-jwt-key-minimum-32-characters-long"

# AI
GEMINI_API_KEY="your-gemini-api-key"

# Cloudflare R2 Storage
R2_ACCOUNT_ID="your-r2-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="your-r2-bucket-name"

# Environment
# NODE_ENV="development"

# Logging (optional)
# LOG_LEVEL="info"

# Next.js Bundle Analyzer (optional)
# ANALYZE="true"
